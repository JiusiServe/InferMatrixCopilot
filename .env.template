# Copy to .env and fill in. NEVER commit .env.

# LLM — Anthropic SDK compatible endpoint (Anthropic or DeepSeek's /anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
AGENT_MODEL=claude-sonnet-5
REVIEWER_MODEL=
INTENT_MODEL=
# Dual-path (双路径) model tiers for agent reasoning. The run's tier is chosen
# from intent — eco by default, performance only when the user explicitly asks
# for the high-performance model (or --performance). Both empty -> AGENT_MODEL
# (the split is a no-op until you set at least PERFORMANCE_MODEL).
ECO_MODEL=
PERFORMANCE_MODEL=
CLAUDE_CODE_ATTREBUTION_HEADER=0

# Repos: JSON map of repo name -> local path
REPO_PATHS={"vllm-omni": "/rebase/vllm-omni"}
DEFAULT_REPO=vllm-omni

# Push safety: pushes are dry-run unless this is 1
ALLOW_PUSH=0

# External locked rebase pipeline (adapter zero delegates to it)
REBASE_ORCHESTRATOR_CMD=omni-rebase-orchestrator --dry-run

# Escalation email (optional; Resend first, SMTP fallback)
NOTIFY_EMAIL=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# (empty -> single-shot reviewer fallback). Requires the claude CLI.

# Mixture-of-Agents (optional, design W6). JSON, SINGLE-QUOTED. Members need a
# MODEL_PRICES-known model; api_key_env NAMES an env var (preferred over raw
# api_key). MoA runs on full-depth PR reviews / performance-mode issue answers
# (MOA_WHEN=off|full|performance|always), capped by MOA_MAX_USD per run.
# LLM_MIXTURE='{"members": [{"model": "deepseek-chat"}, {"model": "claude-sonnet-5", "api_key_env": "MOA_KEY_B"}]}'
