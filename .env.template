# Copy to .env and fill in. NEVER commit .env.

# LLM — Anthropic SDK compatible endpoint (Anthropic or DeepSeek's /anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
AGENT_MODEL=claude-sonnet-5
REVIEWER_MODEL=
INTENT_MODEL=
# Dual-path (双路径) model tiers for agent reasoning. The run's tier is chosen
# from intent — eco by default, performance only when the user explicitly asks
# for the high-performance model (or --performance).
#
# Each tier is EITHER fully unset (eco inherits AGENT_MODEL on the shared
# backend; performance requests then FAIL UPFRONT — never a silent fallback),
# OR model-only (a different model on the shared ANTHROPIC_* backend), OR
# model+base_url+api_key all three (an independent backend). Partial URL/key
# combos are startup errors. Every response's served model is checked against
# the request (MODEL_MISMATCH_POLICY=fail by default — endpoints that silently
# map foreign model names, e.g. claude-* on api.deepseek.com, kill the run
# with an exact message instead of mislabeling it). Verify with:
#   ./infermatrix-copilot doctor --probe
ECO_MODEL=
ECO_BASE_URL=
ECO_API_KEY=
PERFORMANCE_MODEL=
PERFORMANCE_BASE_URL=
PERFORMANCE_API_KEY=
# MODEL_MISMATCH_POLICY=warn   # explicit opt-down: accept substitutions loudly
# MODEL_ALIASES='{"requested-name": "served-name"}'  # audited equivalences only
CLAUDE_CODE_ATTREBUTION_HEADER=0

# Repos: JSON map of repo name -> local path (machine-specific; .env is gitignored,
# which is why absolute paths belong HERE and never in a committed file).
REPO_PATHS={"vllm-omni": "/path/to/vllm-omni"}
DEFAULT_REPO=vllm-omni

# alias -> "owner/repo" GitHub identity, used to route pasted GitHub URLs to a
# configured repo. Optional when the checkout's origin remote already points at
# that owner/repo; without either, URL commands cannot route to the alias
# (`doctor` warns about this).
REPO_FULL_NAMES={"vllm-omni": "vllm-project/vllm-omni"}

# Fallback used by adapters/<repo>/manifest.yaml when no .env is in reach; the
# manifest references these as ${VLLM_OMNI_REPO} / ${VLLM_UPSTREAM_REPO} so the
# committed manifest stays portable. REPO_PATHS above takes precedence.
VLLM_OMNI_REPO=/path/to/vllm-omni
VLLM_UPSTREAM_REPO=/path/to/vllm

# Push safety: pushes are dry-run unless this is 1
ALLOW_PUSH=0

# External locked rebase pipeline (adapter zero delegates to it)
REBASE_ORCHESTRATOR_CMD=omni-rebase-orchestrator --dry-run

# Escalation email (optional; Resend first, SMTP fallback)
NOTIFY_EMAIL=
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# (empty -> single-shot reviewer fallback). Requires the claude CLI.

# Mixture-of-Agents (optional, design W6). JSON, SINGLE-QUOTED. Members need a
# MODEL_PRICES-known model; api_key_env NAMES an env var (preferred over raw
# api_key). MoA runs on full-depth PR reviews / performance-mode issue answers
# (MOA_WHEN=off|full|performance|always), capped by MOA_MAX_USD per run.
# LLM_MIXTURE='{"members": [{"model": "deepseek-chat"}, {"model": "claude-sonnet-5", "api_key_env": "MOA_KEY_B"}]}'
